{
    "name": "qemu-gui",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "gtkx dev src/dev.tsx",
        "build": "gtkx build",
        "typecheck": "tsc --noEmit",
        "start": "node dist/bundle.js",
        "bundle": "gtkx build && tsx scripts/bundle.ts",
        "build:sea": "bash scripts/build-sea.sh",
        "build:appimage": "bash scripts/build-appimage.sh"
    },
    "gtkx": {
        "appId": "com.qemugui.app"
    },
    "dependencies": {
        "@gtkx/css": "^0.21.0",
        "@gtkx/ffi": "^0.21.0",
        "@gtkx/react": "^0.21.0",
        "react": "^19.2.5"
    },
    "devDependencies": {
        "@gtkx/cli": "^0.21.0",
        "@types/node": "^22.19.17",
        "@types/react": "^19.2.14",
        "esbuild": "^0.27.4",
        "postject": "1.0.0-alpha.6",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.10"
    }
}
